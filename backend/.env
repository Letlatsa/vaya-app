# MongoDB Connection String
# Replace with your MongoDB connection URI
# For local: mongodb://localhost:27017/vaya
# For Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/vaya?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/VayaRides

# Server Port
PORT=5000

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Node Environment
NODE_ENV=development

# Gmail Configuration
# For Gmail, you need to use an App Password, not your regular password
# Get App Password from: https://myaccount.google.com/apppasswords
# 1. Enable 2-Step Verification on your Google account
# 2. Go to Security > App Passwords
# 3. Generate a new app password for "Mail"
EMAIL_USER=kadijodeliveries@gmail.com
EMAIL_PASS=ixqw rpwn iyrj aryx

# ===========================================
# Vaya App Monorepo - Root .gitignore
# ===========================================

# Dependencies
node_modules/
*/node_modules/

# Environment files
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Expo (frontend)
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Metro
.metro-health-check*

# Native builds
android/
ios/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS
.DS_Store
*.pem

# TypeScript
*.tsbuildinfo

# IDE
.idea/
.vscode/
*.swp
*.swo

# Misc
*.cache
